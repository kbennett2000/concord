# Concord runtime configuration. Copy to `.env` (gitignored) and edit as needed.
# `docker compose` reads this file automatically; `make run` honors BIBLE_API_PORT.

# Host port the API is served on. Changing this is a one-line edit — no code change.
# (The container always listens on 8000 internally; compose remaps the host port.)
BIBLE_API_PORT=8000

# Allowed CORS origins, comma-separated. Default `*` (all origins) suits LAN use;
# the API is read-only and unauthenticated. Example restriction:
#   CONCORD_CORS_ORIGINS=http://192.168.1.10:3000,http://192.168.1.11:8080
CONCORD_CORS_ORIGINS=*

# Path to the built bible.db. Default `bible.db` (in the working directory; baked to
# /app/bible.db in the Docker image). The API refuses to start if it is missing.
BIBLE_DB_PATH=bible.db

# Translation used when ?translations= is omitted. Must be a loaded translation, or the
# API refuses to start. Default KJV.
CONCORD_DEFAULT_TRANSLATION=KJV

# Max concurrent /v1/semantic-search inferences. Each runs an ONNX forward pass; on a weak
# ~2-core non-AVX2 box that can take hundreds of ms to seconds, so the default 2 (≈ one
# inference per core) sheds excess with 503 + Retry-After to keep the box responsive. Raise
# it on beefier / AVX2 hardware; 0 disables the cap. This bounds how MANY inferences run at
# once; how LONG any one runs is bounded separately by CONCORD_SEMANTIC_TIMEOUT_S below
# (see docs/SECURITY.md, docs/adr/ADR-0001).
CONCORD_SEMANTIC_MAX_CONCURRENCY=2

# Per-inference wall-clock deadline for /v1/semantic-search, in seconds (float). A single query
# that overruns this budget is shed with 503 + Retry-After. Default 10s — comfortably above a
# legitimately slow non-AVX2 query, so it fires only on a pathological/hung pass; 0 disables it.
# This bounds how LONG a caller waits, not CPU: a timed-out inference runs to completion and keeps
# its concurrency slot until it does (so the cap stays coupled to real CPU). Still set a client /
# reverse-proxy read-timeout as defense-in-depth (see docs/SECURITY.md, docs/adr/ADR-0002).
CONCORD_SEMANTIC_TIMEOUT_S=10
