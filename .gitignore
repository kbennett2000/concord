# Environment
.env
.env.*
!.env.example

# Built database (Docker build artifact — never committed)
bible.db
*.db-journal
*.db-wal
*.db-shm

# Embedding model weights (large build artifact, fetched at build/test — never committed)
models/

# Built embeddings database (v2 build artifact — never committed)
embeddings.db

# Non-distributable data (local-only translations)
data/private/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code local settings (shared .claude/ settings stay tracked)
.claude/settings.local.json

# Raw original-language source files (STEPBible TAGNT/TAHOT/lexicons) — re-derivable,
# large, not committed; the parsers under scripts/ emit the committed derived JSON.
data/original/
